# ============================================================================
# NextJS Server Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual credentials
# For AWS RDS deployment, use the RDS endpoint and credentials

# ── Database Configuration (AWS RDS MySQL) ──────────────────────────────────
# AWS RDS MySQL Instance
DB_HOST=hacamined.ch8i62460w7g.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=Admin
DB_PASSWORD=fANTASTIC!4123
DB_NAME=hackamined
DB_SSL=true

# For local development (comment out RDS settings above and use these):
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=hackamined
# DB_SSL=false

# ── Server Configuration ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── External Services (for deployment on separate servers) ──────────────────
# GenAI FastAPI Server URL
GENAI_URL=http://localhost:8000

# ── Simulator Configuration ─────────────────────────────────────────────────
# How often the simulator generates new data (in milliseconds)
SIMULATOR_INTERVAL_MS=15000

# ── JWT & Authentication ────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# ── CORS Configuration ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
