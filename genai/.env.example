# ============================================================
# LUMIN.AI - Environment Configuration
# ============================================================

# LLM Configuration (Groq recommended - free at https://console.groq.com)
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# RAG Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# LangSmith Configuration (https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=hackamined-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Paths (defaults work out of the box)
# INVERTER_MANUAL_PATH=./2cdb179b-9321-4b69-871a-ff5f5df3b3ef.pdf
# VECTOR_STORE_DIR=./vector_store
# TICKET_DIR=./tickets
